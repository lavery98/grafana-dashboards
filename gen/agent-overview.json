{
   "editable": true,
   "graphTooltip": 1,
   "links": [
      {
         "asDropdown": true,
         "includeVars": true,
         "keepTime": true,
         "tags": [
            "grafana-agent"
         ],
         "title": "Grafana Agent Dashboards",
         "type": "dashboards"
      }
   ],
   "panels": [
      {
         "collapsed": false,
         "gridPos": {
            "h": 1,
            "w": 24,
            "x": 0,
            "y": 0
         },
         "id": 1,
         "title": "Agent Stats",
         "type": "row"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "fieldConfig": {
            "defaults": {
               "color": {
                  "mode": "fixed"
               }
            },
            "overrides": [
               {
                  "matcher": {
                     "id": "byName",
                     "options": "Uptime"
                  },
                  "properties": [
                     {
                        "id": "unit",
                        "value": "s"
                     }
                  ]
               }
            ]
         },
         "gridPos": {
            "h": 8,
            "w": 24,
            "x": 0,
            "y": 1
         },
         "id": 2,
         "options": {
            "cellHeight": "sm",
            "footer": {
               "countRows": false,
               "reducer": [ ],
               "show": false
            },
            "showHeader": true
         },
         "pluginVersion": "v10.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "count by (cluster, namespace, instance, version) (agent_build_info{cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"${namespace}/agent\"})",
               "format": "table",
               "instant": true,
               "intervalFactor": null
            },
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasouce"
               },
               "expr": "max by (cluster, namespace, instance) (time() - process_start_time_seconds{cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"${namespace}/agent\"})",
               "format": "table",
               "instant": true,
               "intervalFactor": null
            }
         ],
         "title": "Agent Stats",
         "transformations": [
            {
               "id": "merge"
            },
            {
               "id": "organize",
               "options": {
                  "excludeByName": {
                     "Time": true,
                     "Value #A": true
                  },
                  "indexByName": {
                     "Value #B": 4,
                     "cluster": 0,
                     "instance": 2,
                     "namespace": 1,
                     "version": 3
                  },
                  "renameByName": {
                     "Value #B": "Uptime"
                  }
               }
            }
         ],
         "type": "table"
      },
      {
         "collapsed": true,
         "gridPos": {
            "h": 1,
            "w": 24,
            "x": 0,
            "y": 9
         },
         "id": 3,
         "panels": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "fieldConfig": {
                  "defaults": {
                     "color": {
                        "mode": "palette-classic"
                     },
                     "custom": {
                        "axisCenteredZero": false,
                        "axisColorMode": "text",
                        "axisLabel": "",
                        "axisPlacement": "auto",
                        "barAlignment": 0,
                        "drawStyle": "line",
                        "fillOpacity": 0,
                        "gradientMode": "none",
                        "hideFrom": {
                           "legend": false,
                           "tooltip": false,
                           "viz": false
                        },
                        "lineInterpolation": "linear",
                        "lineWidth": 1,
                        "pointSize": 5,
                        "scaleDistribution": {
                           "type": "linear"
                        },
                        "showPoints": "auto",
                        "spanNulls": false,
                        "stacking": {
                           "mode": "none"
                        },
                        "thresholdsStyle": {
                           "mode": "off"
                        }
                     },
                     "unit": "ms"
                  }
               },
               "gridPos": {
                  "h": 8,
                  "w": 12,
                  "x": 0,
                  "y": 0
               },
               "id": 4,
               "pluginVersion": "v10.4.0",
               "targets": [
                  {
                     "datasource": {
                        "type": "prometheus",
                        "uid": "$datasource"
                     },
                     "expr": "sum(rate(prometheus_target_sync_length_seconds_sum{cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"${namespace}/agent\"}[$__rate_interval])) by (instance, scrape_job) * 1e3",
                     "format": "time_series",
                     "legendFormat": "{{ instance }}/{{ scrape_job }}"
                  }
               ],
               "title": "Target Sync",
               "type": "timeseries"
            },
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "fieldConfig": {
                  "defaults": {
                     "color": {
                        "mode": "palette-classic"
                     },
                     "custom": {
                        "axisCenteredZero": false,
                        "axisColorMode": "text",
                        "axisLabel": "",
                        "axisPlacement": "auto",
                        "barAlignment": 0,
                        "drawStyle": "line",
                        "fillOpacity": 20,
                        "gradientMode": "none",
                        "hideFrom": {
                           "legend": false,
                           "tooltip": false,
                           "viz": false
                        },
                        "lineInterpolation": "linear",
                        "lineWidth": 1,
                        "pointSize": 5,
                        "scaleDistribution": {
                           "type": "linear"
                        },
                        "showPoints": "auto",
                        "spanNulls": false,
                        "stacking": true,
                        "thresholdsStyle": {
                           "mode": "off"
                        }
                     }
                  }
               },
               "gridPos": {
                  "h": 8,
                  "w": 12,
                  "x": 12,
                  "y": 0
               },
               "id": 5,
               "options": {
                  "tooltip": {
                     "mode": "multi",
                     "sort": "desc"
                  }
               },
               "pluginVersion": "v10.4.0",
               "targets": [
                  {
                     "datasource": {
                        "type": "prometheus",
                        "uid": "$datasource"
                     },
                     "expr": "sum by (instance) (prometheus_sd_discovered_targets{cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"${namespace}/agent\"})",
                     "format": "time_series",
                     "legendFormat": "{{ instance }}"
                  }
               ],
               "title": "Targets",
               "type": "timeseries"
            }
         ],
         "title": "Prometheus Discovery",
         "type": "row"
      },
