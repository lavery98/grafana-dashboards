   "templating": {
      "list": [
         {
            "label": "Data source",
            "name": "datasource",
            "query": "prometheus",
            "type": "datasource"
         },
         {
            "allValue": ".+",
            "datasource": {
               "type": "prometheus",
               "uid": "${datasource}"
            },
            "includeAll": true,
            "multi": true,
            "name": "cluster",
            "query": "label_values(agent_build_info, cluster)",
            "refresh": 2,
            "sort": 1,
            "type": "query"
         },
         {
            "allValue": ".+",
            "datasource": {
               "type": "prometheus",
               "uid": "${datasource}"
            },
            "includeAll": true,
            "multi": true,
            "name": "namespace",
            "query": "label_values(agent_build_info{cluster=~\"$cluster\"}, namespace)",
            "refresh": 2,
            "sort": 1,
            "type": "query"
         }
      ]
