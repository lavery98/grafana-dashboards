            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "sum(smartmon_device_smart_enabled{cluster=~\"$cluster\", namespace=~\"$namespace\", host=~\"$host\"})-sum(smartmon_device_smart_healthy{cluster=~\"$cluster\", namespace=~\"$namespace\", host=~\"$host\"})",
