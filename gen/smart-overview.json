            "h": 1,
            "w": 24,
            "x": 0,
            "y": 0
         },
         "id": 1,
         "title": "Overview",
         "type": "row"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "fieldConfig": {
            "defaults": {
               "color": {
                  "fixedColor": "text",
                  "mode": "fixed"
               },
               "unit": "none"
            }
         },
         "gridPos": {
            "h": 4,
            "w": 4,
            "x": 0,
            "y": 1
         },
         "id": 2,
         "options": {
            "colorMode": "value",
            "graphMode": "none",
            "justifyMode": "auto",
            "orientation": "auto",
            "reduceOptions": {
               "calcs": [
                  "lastNotNull"
               ],
               "fields": "",
               "values": false
            },
            "textMode": "auto"
         },
         "pluginVersion": "v10.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "sum(smartmon_device_active{cluster=~\"$cluster\", namespace=~\"$namespace\", host=~\"$host\"})",
               "format": "time_series",
               "instant": true,
               "intervalFactor": null
            }
         ],
         "title": "Disks Monitored",
         "type": "stat"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "fieldConfig": {
            "defaults": {
               "color": {
                  "mode": "fixed"
               },
               "custom": {
                  "filterable": true
               }
            }
         },
         "gridPos": {
            "h": 8,
            "w": 20,
            "x": 4,
            "y": 1
         },
         "id": 3,
         "options": {
            "cellHeight": "sm",
            "footer": {
               "countRows": false,
               "enablePagination": true,
               "reducer": [ ],
               "show": false
            },
            "showHeader": true
         },
         "pluginVersion": "v10.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "smartmon_device_info{cluster=~\"$cluster\", namespace=~\"$namespace\", host=~\"$host\"}",
               "format": "table",
               "instant": true,
               "intervalFactor": null
            }
         ],
         "title": "Disk Drives",
         "transformations": [
            {
               "id": "organize",
               "options": {
                  "excludeByName": {
                     "Time": true,
                     "Value": true,
                     "__name__": true,
                     "agent_hostname": true,
                     "cluster": true,
                     "host": true,
                     "instance": true,
                     "job": true,
                     "lun_id": true,
                     "namespace": true,
                     "product": true,
                     "revision": true,
                     "vendor": true
                  },
                  "indexByName": { },
                  "renameByName": {
                     "device": "Device",
                     "device_model": "Device Model",
                     "disk": "Disk",
                     "firmware_version": "Firmware",
                     "model_family": "Model Family",
                     "serial_number": "Serial Number"
                  }
               }
            }
         ],
         "type": "table"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "fieldConfig": {
            "defaults": {
               "color": {
                  "fixedColor": "text",
                  "mode": "thresholds"
               },
