{
   "editable": true,
   "graphTooltip": 1,
   "links": [
      {
         "asDropdown": true,
         "includeVars": true,
         "keepTime": true,
         "tags": [
            "prometheus"
         ],
         "title": "Prometheus Dashboards",
         "type": "dashboards"
      }
   ],
